# LLM provider (one is required). OpenRouter takes priority over OpenAI when set.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# LangSmith tracing (web dashboard). Set LANGSMITH_ENDPOINT to your data region:
#   US (default): https://api.smith.langchain.com
#   EU:           https://eu.api.smith.langchain.com
#   APAC:         https://apac.api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=multi-agent-research-lab
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Optional search provider
TAVILY_API_KEY=

# Runtime config
APP_ENV=local
LOG_LEVEL=INFO
MAX_ITERATIONS=6
TIMEOUT_SECONDS=60
